<Window x:Class="TesterWorkbench.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Embedded SW Tester Workbench"
        MinHeight="720"
        MinWidth="1120"
        Height="820"
        Width="1280">
    <DockPanel>
        <ToolBar DockPanel.Dock="Top">
            <TextBlock Text="Workspace" VerticalAlignment="Center" Margin="8,0,4,0" />
            <TextBox x:Name="WorkspacePathBox" Width="420" />
            <Button Content="Open" Click="OpenWorkspace_Click" Margin="6,0,0,0" />
            <Separator />
            <Button Content="Compile" Click="Compile_Click" />
            <Button Content="Run" Click="Run_Click" />
            <TextBlock x:Name="RunStatusText" Text="Idle" VerticalAlignment="Center" Margin="14,0,0,0" />
        </ToolBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="5" />
                <RowDefinition Height="220" />
            </Grid.RowDefinitions>

            <GroupBox Grid.Column="0" Grid.RowSpan="3" Header="Project Explorer" Margin="6">
                <TreeView x:Name="ProjectTree" SelectedItemChanged="ProjectTree_SelectedItemChanged" />
            </GroupBox>

            <GridSplitter Grid.Column="1" Grid.RowSpan="3" Width="5" HorizontalAlignment="Stretch" />

            <GroupBox Grid.Column="2" Grid.Row="0" Header="YAML Editor" Margin="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="54" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ScrollViewer x:Name="LineNumbersScrollViewer"
                                  Grid.Column="0"
                                  Background="#F3F4F6"
                                  Focusable="False"
                                  HorizontalScrollBarVisibility="Disabled"
                                  IsHitTestVisible="False"
                                  VerticalScrollBarVisibility="Hidden">
                        <TextBlock x:Name="LineNumbersTextBlock"
                                   FontFamily="Consolas"
                                   FontSize="13"
                                   Foreground="#6B7280"
                                   Padding="4,2,8,0"
                                   TextAlignment="Right" />
                    </ScrollViewer>
                    <TextBox x:Name="EditorBox"
                             Grid.Column="1"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             FontFamily="Consolas"
                             FontSize="13"
                             HorizontalScrollBarVisibility="Auto"
                             Padding="4,2,4,2"
                             SelectionBrush="#FBBF24"
                             SelectionOpacity="0.8"
                             TextChanged="EditorBox_TextChanged"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             ScrollViewer.ScrollChanged="EditorBox_ScrollChanged" />
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="3" Grid.RowSpan="3" Width="5" HorizontalAlignment="Stretch" />

            <GroupBox Grid.Column="4" Grid.Row="0" Header="Outline / Properties" Margin="6">
                <StackPanel Margin="8">
                    <TextBlock Text="Selected File" FontWeight="Bold" />
                    <TextBlock x:Name="SelectedFileText" TextWrapping="Wrap" Margin="0,4,0,16" />
                    <TextBlock Text="Current Line" FontWeight="Bold" />
                    <TextBlock x:Name="CurrentLineText" TextWrapping="Wrap" Margin="0,4,0,16" />
                    <TextBlock Text="Report" FontWeight="Bold" />
                    <TextBlock x:Name="ReportPathText" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
            </GroupBox>

            <GridSplitter Grid.Column="2" Grid.Row="1" Grid.ColumnSpan="3" Height="5" HorizontalAlignment="Stretch" />

            <TabControl Grid.Column="2" Grid.Row="2" Grid.ColumnSpan="3" Margin="6">
                <TabItem Header="Problems">
                    <DataGrid x:Name="ProblemsGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="100" />
                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="140" />
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="Console">
                    <TextBox x:Name="ConsoleBox"
                             FontFamily="Consolas"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </TabItem>
                <TabItem Header="Execution Trace">
                    <DataGrid x:Name="ExecutionTraceGrid"
                              AutoGenerateColumns="False"
                              SelectionChanged="ExecutionTraceGrid_SelectionChanged"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Testcase" Binding="{Binding Testcase}" Width="140" />
                            <DataGridTextColumn Header="Phase" Binding="{Binding Phase}" Width="140" />
                            <DataGridTextColumn Header="Command" Binding="{Binding CommandType}" Width="160" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                            <DataGridTextColumn Header="Line" Binding="{Binding SourceLine}" Width="70" />
                            <DataGridTextColumn Header="Path" Binding="{Binding CommandPath}" Width="220" />
                            <DataGridTextColumn Header="Error" Binding="{Binding Error}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="Variables">
                    <DataGrid x:Name="VariablesGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Testcase" Binding="{Binding Testcase}" Width="160" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" />
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="Report">
                    <TextBlock x:Name="ReportTabText"
                               Margin="12"
                               TextWrapping="Wrap" />
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
