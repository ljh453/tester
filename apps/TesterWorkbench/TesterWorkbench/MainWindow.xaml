<Window x:Class="TesterWorkbench.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TesterWorkbench.Core.ViewModels;assembly=TesterWorkbench.Core"
        Title="Embedded SW Tester Workbench"
        MinHeight="720"
        MinWidth="1120"
        Height="820"
        Width="1280">
    <Window.Resources>
        <Style x:Key="PaneHeaderTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Workbench.Brush.TextPrimary}" />
        </Style>

        <Style x:Key="PaneSubtleTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource Workbench.Brush.TextMuted}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="DockPaneBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource Workbench.Brush.PanelBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Workbench.Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="IdeToolbarButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="IdeToggleButtonStyle"
               TargetType="{x:Type ToggleButton}"
               BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type vm:WorkbenchCommandBlock}"
                                  ItemsSource="{Binding Children}">
            <StackPanel>
                <Border Margin="0,3,0,5"
                        Padding="8,7"
                        CornerRadius="4"
                        Cursor="Hand"
                        MouseEnter="GuiCommandBlock_MouseEnter"
                        PreviewMouseLeftButtonDown="GuiCommandBlock_MouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="GuiCommandBlock_PreviewMouseLeftButtonUp"
                        PreviewMouseRightButtonDown="GuiCommandBlock_PreviewMouseRightButtonDown"
                        PreviewMouseRightButtonUp="GuiCommandBlock_PreviewMouseRightButtonUp">
                    <Border.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Delete"
                                      Click="GuiDeleteSelectedCommands_Click" />
                        </ContextMenu>
                    </Border.ContextMenu>
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Background" Value="{DynamicResource Workbench.Brush.PanelBackgroundAlt}" />
                            <Setter Property="BorderBrush" Value="{Binding AccentColor}" />
                            <Setter Property="BorderThickness" Value="4,1,1,1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelectedForBulkAction}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Workbench.Brush.ControlBackgroundPressed}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource Workbench.Brush.Accent}" />
                                    <Setter Property="BorderThickness" Value="4,2,2,2" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsCurrentExecution}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Workbench.Brush.ControlBackgroundPressed}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource Workbench.Brush.Accent}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsDragInsertionTarget}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Workbench.Brush.ControlBackgroundHover}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource Workbench.Brush.Accent}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22" />
                            <ColumnDefinition Width="22" />
                            <ColumnDefinition Width="42" />
                            <ColumnDefinition Width="82" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="72" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="☰"
                                   Cursor="SizeAll"
                                   Foreground="{DynamicResource Workbench.Brush.TextMuted}"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Tag="CommandDragHandle"
                                   ToolTip="Drag to move command"
                                   PreviewMouseLeftButtonDown="GuiCommandDragHandle_MouseLeftButtonDown"
                                   PreviewMouseMove="GuiCommandBlock_PreviewMouseMove"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding BreakpointMarker}"
                                   Foreground="{DynamicResource Workbench.Brush.Accent}"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding DisplayIndex}"
                                   Foreground="{DynamicResource Workbench.Brush.TextMuted}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3"
                                   Text="{Binding DisplayType}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="4"
                                   Text="{Binding Summary}"
                                   Foreground="{DynamicResource Workbench.Brush.TextSecondary}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="5"
                                   Text="{Binding LineRangeText}"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   Foreground="{DynamicResource Workbench.Brush.TextMuted}"
                                   TextAlignment="Right"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <Border Margin="42,0,0,6"
                        Padding="8,4"
                        Background="{DynamicResource Workbench.Brush.ControlBackgroundPressed}"
                        BorderBrush="{DynamicResource Workbench.Brush.Accent}"
                        BorderThickness="1"
                        CornerRadius="3">
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDragInsertionTarget}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding DragInsertionText}"
                               Foreground="{DynamicResource Workbench.Brush.TextPrimary}"
                               FontSize="12" />
                </Border>
            </StackPanel>
        </HierarchicalDataTemplate>

        <DataTemplate DataType="{x:Type vm:WorkbenchCommandCatalogGroup}">
            <StackPanel Margin="0,0,0,10">
                <TextBlock Text="{Binding Name}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Workbench.Brush.TextSecondary}"
                           Margin="0,0,0,5" />
                <ItemsControl ItemsSource="{Binding Commands}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:WorkbenchCommandDefinition}">
                            <Border Margin="0,0,6,6"
                                    Padding="7,5"
                                    Background="{DynamicResource Workbench.Brush.ControlBackground}"
                                    BorderBrush="{DynamicResource Workbench.Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Cursor="Hand"
                                    PreviewMouseLeftButtonDown="CommandCatalogItem_MouseLeftButtonDown"
                                    PreviewMouseMove="CommandCatalogItem_PreviewMouseMove"
                                    ToolTip="{Binding Description}">
                                <StackPanel Width="138">
                                    <TextBlock Text="{Binding CommandType}"
                                               FontFamily="Consolas"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Workbench.Brush.TextPrimary}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding RequiredArgsText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource Workbench.Brush.TextMuted}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:WorkbenchCommandArgument}">
            <StackPanel Margin="0,0,0,8">
                <Grid Margin="0,0,0,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Name}"
                               Foreground="{DynamicResource Workbench.Brush.TextSecondary}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding RequirementText}"
                               Foreground="{DynamicResource Workbench.Brush.TextMuted}"
                               FontSize="11" />
                </Grid>
                <TextBox Text="{Binding Value, Mode=OneWay}"
                         Tag="{Binding}"
                         IsEnabled="{Binding IsScalarEditable}"
                         LostFocus="GuiCommandArgumentTextBox_LostFocus"
                         PreviewKeyDown="GuiCommandArgumentTextBox_PreviewKeyDown">
                    <TextBox.Style>
                        <Style TargetType="{x:Type TextBox}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSuggestions}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <ComboBox ItemsSource="{Binding Suggestions}"
                          Text="{Binding Value, Mode=OneWay}"
                          Tag="{Binding}"
                          IsEditable="True"
                          IsTextSearchEnabled="True"
                          IsEnabled="{Binding IsScalarEditable}"
                          SelectionChanged="GuiCommandArgumentComboBox_SelectionChanged"
                          LostFocus="GuiCommandArgumentComboBox_LostFocus"
                          PreviewKeyDown="GuiCommandArgumentComboBox_PreviewKeyDown">
                    <ComboBox.Style>
                        <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource {x:Type ComboBox}}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSuggestions}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <DockPanel Background="{DynamicResource Workbench.Brush.AppBackground}">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Save"
                          InputGestureText="Ctrl+S"
                          Click="Save_Click" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Settings..."
                          Click="Settings_Click" />
            </MenuItem>
        </Menu>
        <ToolBar DockPanel.Dock="Top">
            <TextBlock Text="Workspace" VerticalAlignment="Center" Margin="8,0,4,0" />
            <TextBox x:Name="WorkspacePathBox" Width="420" />
            <Button Content="..."
                    Click="OpenWorkspace_Click"
                    Margin="6,0,0,0"
                    Style="{StaticResource IdeToolbarButtonStyle}"
                    ToolTip="Open workspace" />
            <Separator />
            <Button Content="💾"
                    Click="Save_Click"
                    Style="{StaticResource IdeToolbarButtonStyle}"
                    ToolTip="Save YAML file" />
            <Separator />
            <Button Content="✓"
                    Click="Compile_Click"
                    Style="{StaticResource IdeToolbarButtonStyle}"
                    ToolTip="Compile" />
            <Button Content="▶"
                    Click="Run_Click"
                    Style="{StaticResource IdeToolbarButtonStyle}"
                    ToolTip="Run" />
            <Button Content="⏸"
                    Click="Pause_Click"
                    Style="{StaticResource IdeToolbarButtonStyle}"
                    ToolTip="Pause" />
            <Button Content="▶"
                    Click="Resume_Click"
                    Style="{StaticResource IdeToolbarButtonStyle}"
                    ToolTip="Resume" />
            <Button Content="■"
                    Click="Stop_Click"
                    Style="{StaticResource IdeToolbarButtonStyle}"
                    ToolTip="Stop" />
            <Button Content="●"
                    Click="ToggleBreakpoint_Click"
                    Style="{StaticResource IdeToolbarButtonStyle}"
                    ToolTip="Toggle breakpoint at caret line" />
            <TextBlock x:Name="RunStatusText" Text="Idle" VerticalAlignment="Center" Margin="14,0,0,0" />
            <Separator />
            <CheckBox x:Name="AutoFocusLineCheckBox"
                      Content="Auto Focus Line"
                      Checked="AutoFocusLine_Changed"
                      Unchecked="AutoFocusLine_Changed"
                      VerticalAlignment="Center" />
            <Separator />
            <ToggleButton x:Name="GuiEditorToggleButton"
                          Content="◨"
                          IsChecked="True"
                          Click="GuiEditorToggle_Click"
                          Style="{StaticResource IdeToggleButtonStyle}"
                          ToolTip="Show or hide GUI Editor"
                          VerticalAlignment="Center" />
        </ToolBar>

        <Grid x:Name="WorkbenchRootGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="280" />
                <RowDefinition Height="5" />
                <RowDefinition Height="220" MinHeight="160" />
            </Grid.RowDefinitions>

            <Border x:Name="ProjectExplorerPane"
                    Grid.Column="0"
                    Grid.RowSpan="3"
                    Margin="6"
                    Style="{StaticResource DockPaneBorderStyle}">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="9,7"
                            BorderBrush="{DynamicResource Workbench.Brush.Border}"
                            BorderThickness="0,0,0,1"
                            Background="{DynamicResource Workbench.Brush.PanelBackgroundAlt}">
                        <Grid>
                            <TextBlock Text="Project / Test Explorer"
                                       Style="{StaticResource PaneHeaderTextStyle}" />
                            <TextBlock Text="dockable"
                                       HorizontalAlignment="Right"
                                       Style="{StaticResource PaneSubtleTextStyle}" />
                        </Grid>
                    </Border>
                    <TreeView x:Name="ProjectTree" SelectedItemChanged="ProjectTree_SelectedItemChanged" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Grid.RowSpan="3"
                          Width="5"
                          HorizontalAlignment="Stretch" />

            <Grid x:Name="EditorDockHost"
                  Grid.Column="2"
                  Grid.Row="0"
                  Margin="6,6,6,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="YamlEditorColumn" Width="*" MinWidth="360" />
                    <ColumnDefinition x:Name="YamlGuiSplitterColumn" Width="5" />
                    <ColumnDefinition x:Name="GuiEditorColumn" Width="1.12*" MinWidth="300" />
                    <ColumnDefinition x:Name="GuiPropertiesSplitterColumn" Width="5" />
                    <ColumnDefinition x:Name="GuiPropertiesColumn" Width="280" MinWidth="220" />
                </Grid.ColumnDefinitions>

                <Border x:Name="YamlEditorPane"
                        Grid.Column="0"
                        Style="{StaticResource DockPaneBorderStyle}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top"
                                Padding="9,7"
                                BorderBrush="{DynamicResource Workbench.Brush.Border}"
                                BorderThickness="0,0,0,1"
                                Background="{DynamicResource Workbench.Brush.PanelBackgroundAlt}">
                            <Grid>
                                <TextBlock Text="YAML Editor"
                                           Style="{StaticResource PaneHeaderTextStyle}" />
                                <TextBlock Text="line synced"
                                           HorizontalAlignment="Right"
                                           Style="{StaticResource PaneSubtleTextStyle}" />
                            </Grid>
                        </Border>
                        <Grid PreviewMouseWheel="YamlEditor_PreviewMouseWheel">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="54" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ScrollViewer x:Name="LineNumbersScrollViewer"
                                          Grid.Column="0"
                                          Background="{DynamicResource Workbench.Brush.EditorGutter}"
                                          Cursor="Hand"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Disabled"
                                          PreviewMouseLeftButtonDown="LineNumbers_PreviewMouseLeftButtonDown"
                                          ToolTip="Breakpoint boxes appear only on command lines."
                                          VerticalScrollBarVisibility="Hidden">
                                <TextBlock x:Name="LineNumbersTextBlock"
                                           FontFamily="Consolas"
                                           FontSize="13"
                                           Foreground="{DynamicResource Workbench.Brush.TextMuted}"
                                           Padding="4,2,8,0"
                                           TextAlignment="Right" />
                            </ScrollViewer>
                            <Grid Grid.Column="1">
                                <TextBox x:Name="EditorBox"
                                         AcceptsReturn="True"
                                         AcceptsTab="True"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         Background="{DynamicResource Workbench.Brush.EditorBackground}"
                                         Foreground="{DynamicResource Workbench.Brush.TextPrimary}"
                                         CaretBrush="{DynamicResource Workbench.Brush.TextPrimary}"
                                         HorizontalScrollBarVisibility="Auto"
                                         Padding="4,2,4,2"
                                         PreviewKeyDown="EditorBox_PreviewKeyDown"
                                         SelectionBrush="{DynamicResource Workbench.Brush.EditorSelection}"
                                         SelectionOpacity="0.8"
                                         SelectionChanged="EditorBox_SelectionChanged"
                                         SizeChanged="EditorBox_SizeChanged"
                                         TextChanged="EditorBox_TextChanged"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.ScrollChanged="EditorBox_ScrollChanged" />
                                <Canvas x:Name="EditorOverlayCanvas"
                                        ClipToBounds="True"
                                        IsHitTestVisible="False">
                                    <Border x:Name="CurrentExecutionLineMarker"
                                            Background="{DynamicResource Workbench.Brush.CurrentLine}"
                                            Opacity="0.28"
                                            Visibility="Collapsed" />
                                    <Border x:Name="CurrentExecutionLineBadge"
                                            Canvas.Top="6"
                                            Canvas.Right="22"
                                            Background="{DynamicResource Workbench.Brush.BadgeBackground}"
                                            CornerRadius="3"
                                            Opacity="0.88"
                                            Padding="8,4"
                                            Visibility="Collapsed">
                                        <TextBlock x:Name="CurrentExecutionLineBadgeText"
                                                   Foreground="{DynamicResource Workbench.Brush.BadgeText}"
                                                   FontSize="12" />
                                    </Border>
                                </Canvas>
                            </Grid>
                        </Grid>
                    </DockPanel>
                </Border>

                <GridSplitter x:Name="YamlGuiSplitter"
                              Grid.Column="1"
                              Width="5"
                              HorizontalAlignment="Stretch"
                              DragCompleted="YamlGuiSplitter_DragCompleted" />

                <Border x:Name="GuiEditorPane"
                        Grid.Column="2"
                        Style="{StaticResource DockPaneBorderStyle}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top"
                                Padding="9,7"
                                BorderBrush="{DynamicResource Workbench.Brush.Border}"
                                BorderThickness="0,0,0,1"
                                Background="{DynamicResource Workbench.Brush.PanelBackgroundAlt}">
                            <Grid>
                                <TextBlock Text="GUI Testcase Editor"
                                           Style="{StaticResource PaneHeaderTextStyle}" />
                                <TextBlock Text="block flow"
                                           HorizontalAlignment="Right"
                                           Style="{StaticResource PaneSubtleTextStyle}" />
                            </Grid>
                        </Border>

                        <StackPanel DockPanel.Dock="Top" Margin="10,8,10,0">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="GuiTestcaseComboBox"
                                          DisplayMemberPath="Name"
                                          SelectionChanged="GuiTestcaseComboBox_SelectionChanged" />
                                <Border Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Padding="8,4"
                                        Background="{DynamicResource Workbench.Brush.ControlBackground}"
                                        BorderBrush="{DynamicResource Workbench.Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                    <TextBlock x:Name="GuiTestcaseLineText"
                                               Foreground="{DynamicResource Workbench.Brush.TextSecondary}" />
                                </Border>
                            </Grid>
                            <TextBlock x:Name="GuiTestcaseMetadataText"
                                       Foreground="{DynamicResource Workbench.Brush.TextMuted}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Fold"
                                           Foreground="{DynamicResource Workbench.Brush.TextMuted}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <Button Content="⤢"
                                        Click="GuiExpandAll_Click"
                                        Margin="0,0,6,0"
                                        Style="{StaticResource IdeToolbarButtonStyle}"
                                        ToolTip="Expand all blocks" />
                                <Button Content="⤡"
                                        Click="GuiFoldAll_Click"
                                        Margin="0,0,6,0"
                                        Style="{StaticResource IdeToolbarButtonStyle}"
                                        ToolTip="Fold all blocks" />
                                <Button Content="2"
                                        Click="GuiFoldLevel2_Click"
                                        Margin="0,0,6,0"
                                        Style="{StaticResource IdeToolbarButtonStyle}"
                                        ToolTip="Fold from level 2" />
                                <Button Content="3"
                                        Click="GuiFoldLevel3_Click"
                                        Style="{StaticResource IdeToolbarButtonStyle}"
                                        ToolTip="Fold from level 3" />
                            </StackPanel>
                        </StackPanel>

                        <Grid x:Name="GuiSelectionHost"
                              ClipToBounds="True"
                              PreviewMouseLeftButtonDown="GuiSelectionSurface_PreviewMouseLeftButtonDown"
                              PreviewMouseLeftButtonUp="GuiSelectionSurface_PreviewMouseLeftButtonUp"
                              PreviewMouseMove="GuiSelectionSurface_PreviewMouseMove">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="GuiPhaseItems"
                                              Margin="10,0,10,10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:WorkbenchGuiPhase}">
                                        <Border Margin="0,0,0,10"
                                                AllowDrop="True"
                                                Background="{DynamicResource Workbench.Brush.PanelBackground}"
                                                BorderBrush="{DynamicResource Workbench.Brush.Border}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                DragOver="GuiPhase_DragOver"
                                                DragLeave="GuiPhase_DragLeave"
                                                Drop="GuiPhase_Drop">
                                            <DockPanel>
                                                <Border DockPanel.Dock="Top"
                                                        Padding="9,7"
                                                        BorderBrush="{DynamicResource Workbench.Brush.Border}"
                                                        BorderThickness="0,0,0,1"
                                                        Background="{DynamicResource Workbench.Brush.PanelBackgroundAlt}">
                                                    <Grid>
                                                        <TextBlock Text="{Binding Name}"
                                                                   Style="{StaticResource PaneHeaderTextStyle}" />
                                                        <TextBlock Text="{Binding CountText}"
                                                                   HorizontalAlignment="Right"
                                                                   Style="{StaticResource PaneSubtleTextStyle}" />
                                                    </Grid>
                                                </Border>
                                                <Border Margin="9,8,9,0"
                                                        Padding="8,4"
                                                        AllowDrop="True"
                                                        DataContext="{Binding StartDropTarget}"
                                                        DragOver="GuiPhase_DragOver"
                                                        DragLeave="GuiPhase_DragLeave"
                                                        Drop="GuiPhase_Drop">
                                                    <Border.Style>
                                                        <Style TargetType="{x:Type Border}">
                                                            <Setter Property="Background" Value="Transparent" />
                                                            <Setter Property="BorderBrush" Value="Transparent" />
                                                            <Setter Property="BorderThickness" Value="1" />
                                                            <Setter Property="CornerRadius" Value="3" />
                                                            <Setter Property="MinHeight" Value="8" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDragInsertionTarget}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource Workbench.Brush.ControlBackgroundPressed}" />
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Workbench.Brush.Accent}" />
                                                                    <Setter Property="MinHeight" Value="26" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding DragInsertionText}"
                                                               Foreground="{DynamicResource Workbench.Brush.TextPrimary}"
                                                               FontSize="12" />
                                                </Border>
                                                <TreeView ItemsSource="{Binding Blocks}"
                                                          AllowDrop="True"
                                                          BorderThickness="0"
                                                          DragOver="GuiPhase_DragOver"
                                                          DragLeave="GuiPhase_DragLeave"
                                                          Drop="GuiPhase_Drop"
                                                          SelectedItemChanged="GuiBlockTree_SelectedItemChanged">
                                                    <TreeView.ItemContainerStyle>
                                                        <Style TargetType="{x:Type TreeViewItem}">
                                                            <Setter Property="Foreground" Value="{DynamicResource Workbench.Brush.TextPrimary}" />
                                                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                                        </Style>
                                                    </TreeView.ItemContainerStyle>
                                                </TreeView>
                                                <Border Margin="9,0,9,9"
                                                        Padding="8,4"
                                                        AllowDrop="True"
                                                        DataContext="{Binding EndDropTarget}"
                                                        DragOver="GuiPhase_DragOver"
                                                        DragLeave="GuiPhase_DragLeave"
                                                        Drop="GuiPhase_Drop">
                                                    <Border.Style>
                                                        <Style TargetType="{x:Type Border}">
                                                            <Setter Property="Background" Value="Transparent" />
                                                            <Setter Property="BorderBrush" Value="Transparent" />
                                                            <Setter Property="BorderThickness" Value="1" />
                                                            <Setter Property="CornerRadius" Value="3" />
                                                            <Setter Property="MinHeight" Value="8" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDragInsertionTarget}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource Workbench.Brush.ControlBackgroundPressed}" />
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Workbench.Brush.Accent}" />
                                                                    <Setter Property="MinHeight" Value="26" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding DragInsertionText}"
                                                               Foreground="{DynamicResource Workbench.Brush.TextPrimary}"
                                                               FontSize="12" />
                                                </Border>
                                                <Border Margin="9,0,9,9"
                                                        Padding="8,5"
                                                        Background="{DynamicResource Workbench.Brush.ControlBackgroundPressed}"
                                                        BorderBrush="{DynamicResource Workbench.Brush.Accent}"
                                                        BorderThickness="1"
                                                        CornerRadius="3">
                                                    <Border.Style>
                                                        <Style TargetType="{x:Type Border}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDragInsertionTarget}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding DragInsertionText}"
                                                               Foreground="{DynamicResource Workbench.Brush.TextPrimary}"
                                                               FontSize="12" />
                                                </Border>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <Canvas IsHitTestVisible="False">
                                <Border x:Name="GuiDragSelectionRectangle"
                                        Background="#3338BDF8"
                                        BorderBrush="{DynamicResource Workbench.Brush.Accent}"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        Visibility="Collapsed" />
                            </Canvas>
                        </Grid>
                    </DockPanel>
                </Border>

                <GridSplitter x:Name="GuiPropertiesSplitter"
                              Grid.Column="3"
                              Width="5"
                              HorizontalAlignment="Stretch" />

                <Border x:Name="GuiPropertiesPane"
                        Grid.Column="4"
                        Style="{StaticResource DockPaneBorderStyle}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top"
                                Padding="9,7"
                                BorderBrush="{DynamicResource Workbench.Brush.Border}"
                                BorderThickness="0,0,0,1"
                                Background="{DynamicResource Workbench.Brush.PanelBackgroundAlt}">
                            <Grid>
                                <TextBlock Text="Properties"
                                           Style="{StaticResource PaneHeaderTextStyle}" />
                                <TextBlock Text="selected block"
                                           HorizontalAlignment="Right"
                                           Style="{StaticResource PaneSubtleTextStyle}" />
                            </Grid>
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="10">
                                <TextBlock Text="Selected File" FontWeight="SemiBold" />
                                <TextBlock x:Name="SelectedFileText" TextWrapping="Wrap" Margin="0,4,0,6" />
                                <TextBlock x:Name="SaveStatusTextBlock"
                                           Foreground="{DynamicResource Workbench.Brush.TextMuted}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,12" />
                                <TextBlock Text="Current Line" FontWeight="SemiBold" />
                                <TextBlock x:Name="CurrentLineText" TextWrapping="Wrap" Margin="0,4,0,12" />
                                <TextBlock Text="Breakpoints" FontWeight="SemiBold" />
                                <TextBlock x:Name="BreakpointsTextBlock" TextWrapping="Wrap" Margin="0,4,0,12" />
                                <TextBlock Text="Report" FontWeight="SemiBold" />
                                <TextBlock x:Name="ReportPathText" TextWrapping="Wrap" Margin="0,4,0,16" />

                                <Border BorderBrush="{DynamicResource Workbench.Brush.Border}"
                                        BorderThickness="1"
                                        Background="{DynamicResource Workbench.Brush.PanelBackgroundAlt}"
                                        CornerRadius="4"
                                        Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Command"
                                                   FontWeight="SemiBold"
                                                   Padding="9,7" />
                                        <StackPanel Margin="9,0,9,9">
                                            <TextBlock Text="Type" Foreground="{DynamicResource Workbench.Brush.TextMuted}" />
                                            <TextBox x:Name="GuiCommandTypeBox"
                                                     IsReadOnly="True"
                                                     Margin="0,3,0,8" />
                                            <TextBlock Text="Summary" Foreground="{DynamicResource Workbench.Brush.TextMuted}" />
                                            <TextBox x:Name="GuiCommandSummaryBox"
                                                     IsReadOnly="True"
                                                     TextWrapping="Wrap"
                                                     Margin="0,3,0,8" />
                                            <TextBlock Text="Source Range" Foreground="{DynamicResource Workbench.Brush.TextMuted}" />
                                            <TextBox x:Name="GuiCommandLineBox"
                                                     IsReadOnly="True"
                                                     Margin="0,3,0,8" />
                                            <TextBlock Text="Validation" Foreground="{DynamicResource Workbench.Brush.TextMuted}" />
                                            <TextBlock x:Name="GuiCommandValidationText"
                                                       TextWrapping="Wrap"
                                                       Margin="0,3,0,8" />
                                            <TextBlock Text="Arguments" Foreground="{DynamicResource Workbench.Brush.TextMuted}" />
                                            <ItemsControl x:Name="GuiCommandArgumentsControl"
                                                          Margin="0,3,0,8" />
                                            <TextBlock Text="Complex Arguments" Foreground="{DynamicResource Workbench.Brush.TextMuted}" />
                                            <ItemsControl x:Name="GuiCommandComplexArgumentsControl"
                                                          Margin="0,3,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:WorkbenchCommandArgument}">
                                                        <StackPanel Margin="0,0,0,8">
                                                            <Grid Margin="0,0,0,3">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding Name}"
                                                                           Foreground="{DynamicResource Workbench.Brush.TextSecondary}" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding RequirementText}"
                                                                           Foreground="{DynamicResource Workbench.Brush.TextMuted}"
                                                                           FontSize="11" />
                                                            </Grid>
                                                            <TextBox Text="{Binding Value, Mode=OneWay}"
                                                                     Tag="{Binding}"
                                                                     MinHeight="72"
                                                                     AcceptsReturn="True"
                                                                     TextWrapping="NoWrap"
                                                                     HorizontalScrollBarVisibility="Auto"
                                                                     VerticalScrollBarVisibility="Auto"
                                                                     LostFocus="GuiCommandComplexArgumentTextBox_LostFocus">
                                                                <TextBox.Style>
                                                                    <Style TargetType="{x:Type TextBox}">
                                                                        <Setter Property="IsReadOnly" Value="True" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsComplexEditable}" Value="True">
                                                                                <Setter Property="IsReadOnly" Value="False" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBox.Style>
                                                            </TextBox>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border BorderBrush="{DynamicResource Workbench.Brush.Border}"
                                        BorderThickness="1"
                                        Background="{DynamicResource Workbench.Brush.PanelBackgroundAlt}"
                                        CornerRadius="4"
                                        Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Insert Command"
                                                   FontWeight="SemiBold"
                                                   Padding="9,7" />
                                        <ItemsControl x:Name="CommandCatalogGroupsControl"
                                                      Margin="9,0,9,9" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="YAML Source" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBox x:Name="GuiCommandSourceBox"
                                         MinHeight="150"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         IsReadOnly="True"
                                         TextWrapping="NoWrap"
                                         HorizontalScrollBarVisibility="Auto"
                                         VerticalScrollBarVisibility="Auto" />
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="2"
                          Grid.Row="1"
                          Height="5"
                          HorizontalAlignment="Stretch" />

            <TabControl x:Name="BottomPanelHost"
                        Grid.Column="2"
                        Grid.Row="2"
                        Margin="6,3,6,6">
                <TabItem Header="Problems">
                    <DataGrid x:Name="ProblemsGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="100" />
                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="140" />
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="Console">
                    <TextBox x:Name="ConsoleBox"
                             FontFamily="Consolas"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </TabItem>
                <TabItem Header="Execution Trace">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="5" />
                            <RowDefinition Height="170" MinHeight="120" />
                        </Grid.RowDefinitions>
                        <DataGrid x:Name="ExecutionTraceGrid"
                                  AutoGenerateColumns="False"
                                  SelectionChanged="ExecutionTraceGrid_SelectionChanged"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Testcase" Binding="{Binding Testcase}" Width="140" />
                                <DataGridTextColumn Header="Phase" Binding="{Binding Phase}" Width="110" />
                                <DataGridTextColumn Header="Command" Binding="{Binding CommandType}" Width="160" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                                <DataGridTextColumn Header="Line" Binding="{Binding SourceLine}" Width="70" />
                                <DataGridTextColumn Header="Path" Binding="{Binding CommandPath}" Width="200" />
                                <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="220" />
                                <DataGridTextColumn Header="Evidence" Binding="{Binding RawEvidenceRefs}" Width="220" />
                                <DataGridTextColumn Header="Duration" Binding="{Binding DurationDetail}" Width="120" />
                                <DataGridTextColumn Header="Error" Binding="{Binding Error}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <GridSplitter Grid.Row="1"
                                      Height="5"
                                      HorizontalAlignment="Stretch" />
                        <Grid Grid.Row="2" Margin="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.05*" />
                                <ColumnDefinition Width="1.1*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Resolved Inputs"
                                       Foreground="{DynamicResource Workbench.Brush.TextMuted}" />
                            <TextBlock Grid.Column="1"
                                       Text="Outputs / Values"
                                       Foreground="{DynamicResource Workbench.Brush.TextMuted}"
                                       Margin="8,0,0,0" />
                            <TextBlock Grid.Column="2"
                                       Text="Evidence / Duration"
                                       Foreground="{DynamicResource Workbench.Brush.TextMuted}"
                                       Margin="8,0,0,0" />
                            <TextBlock Grid.Column="3"
                                       Text="Error"
                                       Foreground="{DynamicResource Workbench.Brush.TextMuted}"
                                       Margin="8,0,0,0" />
                            <TextBox x:Name="TraceResolvedInputsBox"
                                     Grid.Row="1"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalScrollBarVisibility="Auto" />
                            <TextBox x:Name="TraceOutputsBox"
                                     Grid.Column="1"
                                     Grid.Row="1"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="8,0,0,0" />
                            <TextBox x:Name="TraceEvidenceBox"
                                     Grid.Column="2"
                                     Grid.Row="1"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="8,0,0,0" />
                            <TextBox x:Name="TraceErrorBox"
                                     Grid.Column="3"
                                     Grid.Row="1"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="8,0,0,0" />
                        </Grid>
                    </Grid>
                </TabItem>
                <TabItem Header="Variables">
                    <DataGrid x:Name="VariablesGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Testcase" Binding="{Binding Testcase}" Width="160" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" />
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="Report">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Padding="9,7"
                                BorderBrush="{DynamicResource Workbench.Brush.Border}"
                                BorderThickness="0,0,0,1"
                                Background="{DynamicResource Workbench.Brush.PanelBackgroundAlt}">
                            <DockPanel LastChildFill="True">
                                <Button x:Name="ReportSummaryButton"
                                        DockPanel.Dock="Right"
                                        Content="Open Summary"
                                        Click="OpenReportSummary_Click"
                                        Style="{StaticResource IdeToolbarButtonStyle}"
                                        ToolTip="Open summary.html in the default browser" />
                                <StackPanel>
                                    <TextBlock x:Name="ReportTabText"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="ReportSummaryPathText"
                                               Foreground="{DynamicResource Workbench.Brush.TextMuted}"
                                               TextWrapping="Wrap"
                                               Margin="0,2,12,0" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <WebBrowser x:Name="ReportBrowser"
                                    Grid.Row="1"
                                    Margin="6" />
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
